[settings]
idiomatic_version_file_enable_tools = []
experimental = true

# NOTE: URL の {{`{{version}}`}} は mise のプレースホルダ。chezmoi テンプレートに評価
# されないよう {{`...`}} でエスケープし、リテラルの {{`{{version}}`}} を出力する。
[tools."http:profilecli"]
version = "2.0.1"
url = "https://github.com/grafana/pyroscope/releases/download/v{{`{{version}}`}}/profilecli_{{`{{version}}`}}_darwin_arm64.tar.gz"
checksum = "sha256:2cee2f7a6b695ac6545ed4b284505290485778c43cf720ad468e42e10e2ce2c9"
