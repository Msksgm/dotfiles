#!/bin/bash
# Install / update Homebrew packages from the Brewfile.
# Re-runs on `chezmoi apply` whenever the Brewfile changes
# (the hash below changes with it, so chezmoi detects a new script).
# Brewfile hash: {{ include "Brewfile" | sha256sum }}
set -e

eval "$(/opt/homebrew/bin/brew shellenv)"
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile"
